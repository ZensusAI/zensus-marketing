{
  "cleanUrls": true,
  "redirects": [
    {
      "source": "/privacy",
      "destination": "https://app.zensus.app/privacy",
      "permanent": true
    },
    {
      "source": "/support",
      "destination": "https://app.zensus.app/support",
      "permanent": true
    },
    {
      "source": "/features",
      "destination": "https://zensus.app/#features",
      "permanent": true
    },
    {
      "source": "/forecast",
      "destination": "https://app.zensus.app/forecast",
      "permanent": true
    },
    {
      "source": "/terms",
      "destination": "https://app.zensus.app/terms",
      "permanent": true
    }
  ],
  "headers": [
    {
      "source": "/(.*)",
      "headers": [
        {
          "key": "Strict-Transport-Security",
          "value": "max-age=63072000; includeSubDomains; preload"
        },
        {
          "key": "X-Content-Type-Options",
          "value": "nosniff"
        },
        {
          "key": "X-Frame-Options",
          "value": "DENY"
        },
        {
          "key": "Referrer-Policy",
          "value": "strict-origin-when-cross-origin"
        },
        {
          "key": "Permissions-Policy",
          "value": "camera=(), microphone=(), geolocation=()"
        },
        {
          "key": "Content-Security-Policy",
          "value": "frame-ancestors 'none'"
        }
      ]
    }
  ]
}
