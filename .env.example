# Google One Tap sign-in (ZEN-365). Configure these on Vercel, not in a
# committed file. They are all OPTIONAL: when absent, the Supabase client is
# null and the One Tap prompt never renders, so the site is unaffected.
#
# IMPORTANT: Vite inlines VITE_* at BUILD time. Setting these on Vercel does
# not activate One Tap on an already-deployed bundle, a redeploy is required.

# Supabase project (same public values as apps/landing's NEXT_PUBLIC_SUPABASE_*).
VITE_SUPABASE_URL=
VITE_SUPABASE_ANON_KEY=

# Google OAuth 2.0 Client ID (the same client Supabase uses). Browser-side, no
# secret. Add https://zensus.app and http://localhost:8080 as Authorized
# JavaScript origins in Google Cloud Console.
VITE_GOOGLE_CLIENT_ID=

# Product app origin. One Tap hands off to ${VITE_APP_URL}/auth/handoff after a
# successful sign-in. Defaults to production; use http://localhost:3000 to test
# against a local landing app.
VITE_APP_URL=https://app.zensus.app
